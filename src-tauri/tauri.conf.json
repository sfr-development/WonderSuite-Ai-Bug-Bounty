{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WonderSuite",
  "version": "0.1.4",
  "identifier": "com.wondersuite.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WonderSuite",
        "width": 1200,
        "height": 780,
        "minWidth": 900,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' 'wasm-unsafe-eval'",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' data: blob: asset: http://asset.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost https://generativelanguage.googleapis.com",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJCMEU1NEM2Q0ZCREZGNUIKUldSYi83M1B4bFFPdTBtZGFYcUJIZENxTWxCbzdOTmIxbnhoRVFRMWlQQVVWSDRKdTVxbzdKdzcK",
      "endpoints": [
        "https://github.com/sfr-development/WonderSuite-Ai-Bug-Bounty/releases/latest/download/latest.json"
      ]
    }
  }
}
